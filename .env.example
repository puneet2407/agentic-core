# Copy to .env and fill in

# LLM provider: "claude-cli" (Claude Code CLI, works with Pro/Max login — no key)
#            or "anthropic" (direct API, needs ANTHROPIC_API_KEY).
# Defaults to claude-cli when no API key is set.
LLM_PROVIDER=claude-cli

# Only needed for LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: full path to the claude binary if not on PATH
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Model gateway
DEFAULT_MODEL=claude-sonnet-4-5
PLANNER_MODEL=claude-sonnet-4-5
FAST_MODEL=claude-haiku-4-5-20251001

# Server
PORT=3100

# Auth: when set, all API routes require "Authorization: Bearer <token>".
# Leave unset for solo local use. REQUIRED before exposing to teammates/network.
# API_TOKEN=generate-a-long-random-string

# Long-term memory seeds: loaded at every boot. Copy memory-seed.example.md
# to memory-seed.md and describe YOUR services/conventions.
# MEMORY_SEED_FILE=memory-seed.md

# Multi-repo dev assistant: folder containing all your microservice repos.
# When set, agents get workspace tools (repo discovery, code search, file read, git log).
# WORKSPACE_ROOT=/Users/you/work/my-company

# Limits
MAX_STEPS_PER_TASK=12
MAX_TOKENS_PER_TASK=200000
REQUEST_TIMEOUT_MS=120000

# Logging: debug | info | warn | error
LOG_LEVEL=info
